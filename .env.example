ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
BACKEND_PORT=5100
FRONTEND_PORT=5101

# HTTPS 部署时设为 true；本地 / Docker HTTP 保持 false
# COOKIE_SECURE=false

# 可选：仅当 Subconverter 在远程且无法访问当前域名时，指定可被外网拉取的后端地址
# PUBLIC_BASE_URL=https://sub.example.com
SESSION_SECRET=adminsecret
# 数据库路径（相对运行目录）。源码与 Docker 共用此值；Docker 把宿主机 ./data 挂到对应位置
DB_PATH=./data/subscriptions.db
