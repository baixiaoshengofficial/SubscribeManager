ADMIN_PATH=admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
BACKEND_PORT=3000
# 对外访问端口：开发时为 Vite；Docker 为前端 Nginx 监听端口
FRONTEND_PORT=3000

