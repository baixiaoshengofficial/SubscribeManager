ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
BACKEND_PORT=5100
FRONTEND_PORT=5101

# HTTPS 部署时设为 true；本地 / Docker HTTP 保持 false
# COOKIE_SECURE=false

# 公网可访问的后端地址（Docker 构建前端时用于订阅链接展示，Subconverter 拉节点）
# PUBLIC_BASE_URL=http://127.0.0.1:5100
SESSION_SECRET=adminsecret
# 数据库路径（相对运行目录）。源码与 Docker 共用此值；Docker 把宿主机 ./data 挂到对应位置
DB_PATH=./data/subscriptions.db
